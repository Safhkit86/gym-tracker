# Copia questo file in .env e personalizza per lo sviluppo locale.
# .env non va mai committato (vedi .gitignore).

# --- Postgres ---
POSTGRES_USER=gymtracker
POSTGRES_PASSWORD=gymtracker
POSTGRES_DB=gymtracker
POSTGRES_PORT=5432

# Solo per script lanciati SULL'HOST (npm run dev / db:migrate fuori da
# Docker): auth-service e workout-service caricano .env da soli (vedi
# src/config.ts). docker-compose.yml NON legge questa variabile: costruisce
# la propria DATABASE_URL con host "postgres" (rete interna Docker) a partire
# dalle POSTGRES_* qui sopra, quindi non c'e' conflitto.
DATABASE_URL=postgres://gymtracker:gymtracker@localhost:5432/gymtracker

# --- Redis ---
REDIS_PORT=6379

# --- RabbitMQ ---
RABBITMQ_USER=gymtracker
RABBITMQ_PASSWORD=gymtracker
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
# Solo per progress-service lanciato SULL'HOST: docker-compose.yml usa invece
# l'hostname interno "rabbitmq" (rete Docker), non questo.
RABBITMQ_URL=amqp://gymtracker:gymtracker@localhost:5672

# --- Mailpit (cattura le email di reset/cambio password in locale) ---
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
SMTP_FROM=no-reply@gym-tracker.local
# URL della webapp usato per costruire il link di reset password nell'email
# (e' un link per il browser dell'utente, resta invariato anche dentro Docker).
WEB_APP_URL=http://localhost:5173

# --- Auth service ---
AUTH_SERVICE_PORT=4001
JWT_SECRET=change-me-in-production
# Solo per auth-service lanciato SULL'HOST: docker-compose.yml usa invece
# l'hostname interno "mailpit" (rete Docker), non questi.
SMTP_HOST=localhost
SMTP_PORT=1025

# --- Workout service (fase 2) ---
WORKOUT_SERVICE_PORT=4002

# --- Progress service (fase 3) ---
PROGRESS_SERVICE_PORT=4003

# --- Notify service (fase 4) ---
NOTIFY_SERVICE_PORT=4004

# --- API Gateway ---
# Unico punto di ingresso per i client (web/Android): inoltra ad auth-service
# e workout-service. Vedi CLAUDE.md, "Cosa NON fare".
API_GATEWAY_PORT=4000
# Solo per api-gateway lanciato SULL'HOST: docker-compose.yml usa invece gli
# hostname interni auth-service/workout-service (rete Docker), non queste.
AUTH_SERVICE_URL=http://localhost:4001
WORKOUT_SERVICE_URL=http://localhost:4002
PROGRESS_SERVICE_URL=http://localhost:4003
NOTIFY_SERVICE_URL=http://localhost:4004
