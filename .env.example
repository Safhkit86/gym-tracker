# Copia questo file in .env e personalizza per lo sviluppo locale.
# .env non va mai committato (vedi .gitignore).

# --- Postgres ---
POSTGRES_USER=gymtracker
POSTGRES_PASSWORD=gymtracker
POSTGRES_DB=gymtracker
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- RabbitMQ ---
RABBITMQ_USER=gymtracker
RABBITMQ_PASSWORD=gymtracker
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# --- Auth service ---
AUTH_SERVICE_PORT=4001
JWT_SECRET=change-me-in-production

# --- Workout service (fase 2) ---
WORKOUT_SERVICE_PORT=4002

# --- Progress service (fase 3) ---
PROGRESS_SERVICE_PORT=4003

# --- Notify service (fase 4) ---
NOTIFY_SERVICE_PORT=4004
